    <div class="container mx-auto flex flex-wrap p-5">
      <div class="w-full lg:w-3/4 p-4">
        <h1 class="text-3xl font-bold mb-6 text-gray-800 text-center">
          Welcome, <%= user.name %>
        </h1>
        <div class="max-w-3xl mx-auto my-8 p-6 bg-white shadow-md rounded-lg">
          <h2 class="text-2xl font-semibold mb-4 text-gray-800">Posts</h2>
          <div class="grid grid-cols-1 gap-6">
            <% posts.forEach(function(post) { %>
            <div class="bg-white p-4 rounded shadow-md hover-shadow-lg">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xl font-bold"><%= post.user_name %></h3>
                <p class="text-gray-500 text-sm">
                  <%= new Date(post.created_at).toLocaleString() %>
                </p>
              </div>
              <% if (post.photo) { %>
              <img
                src="/<%= post.photo %>"
                alt="Post Photo"
                class="w-full h-auto mb-2 rounded-lg hover:scale-105 transition duration-300"
              />
              <% } else { %>
              <img
                src="https://source.unsplash.com/random/800x600"
                alt="Random Image"
                class="w-full h-auto mb-2 rounded-lg hover:scale-105 transition duration-300"
              />
              <% } %>
              <p class="text-gray-700 mb-4"><%= post.content %></p>
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                  <button
                    class="flex items-center space-x-1 like-button text-gray-600 hover:text-blue-600 transition duration-300"
                    onclick="toggleLike(this)"
                  >
                    <span class="icon">👍</span>
                    <span class="like-count">0</span>
                  </button>
                  <button
                    class="flex items-center space-x-1 comment-button text-gray-600 hover:text-blue-600 transition duration-300"
                    onclick="toggleComment(this)"
                  >
                    <span class="icon">💬</span>
                    <span class="comment-count">0</span>
                  </button>
                  <button
                    class="flex items-center space-x-1 share-button text-gray-600 hover:text-blue-600 transition duration-300"
                    onclick="toggleShare(this)"
                  >
                    <span class="icon">🔄</span>
                    <span class="share-count">0</span>
                  </button>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <aside class="w-full lg:w-1/4 p-4">
        <div class="bg-white rounded shadow-md p-4">
          <h2 class="text-lg font-semibold mb-4">Followed Users</h2>
          <ul>
            <li class="mb-2">
              <div class="flex items-center space-x-2">
                <img
                  src="https://via.placeholder.com/50"
                  alt="User 1"
                  class="w-8 h-8 rounded-full"
                />
                <span>Pratik Acharya</span>
              </div>
            </li>
            <li class="mb-2">
              <div class="flex items-center space-x-2">
                <img
                  src="https://via.placeholder.com/50"
                  alt="User 2"
                  class="w-8 h-8 rounded-full"
                />
                <span>Navnit Mallick</span>
              </div>
            </li>
            <li class="mb-2">
              <div class="flex items-center space-x-2">
                <img
                  src="https://via.placeholder.com/50"
                  alt="User 3"
                  class="w-8 h-8 rounded-full"
                />
                <span>Pramod Dhami</span>
              </div>
            </li>
            <li class="mb-2">
                <div class="flex items-center space-x-2">
                  <img
                    src="https://via.placeholder.com/50"
                    alt="User 3"
                    class="w-8 h-8 rounded-full"
                  />
                  <span>Prashant Shah</span>
                </div>
              </li>

          </ul>
        </div>
      </aside>
    </div>
      <script> 
        function toggleLike(button) {
             const likeCountSpan = button.querySelector('.like-count'); 
             const icon = button.querySelector('.icon'); 
             if (button.classList.contains('liked')) {
                 button.classList.remove('liked'); 
                 icon.textContent = '👍'; 
                 likeCountSpan.textContent = parseInt(likeCountSpan.textContent) - 1; } 
                 else { button.classList.add('liked'); icon.textContent = '❤️'; likeCountSpan.textContent = parseInt(likeCountSpan.textContent) + 1; } }

                 function toggleComment(button) {
    const commentCountSpan = button.querySelector('.comment-count');
    const icon = button.querySelector('.icon');

    if (button.classList.contains('commented')) {
        button.classList.remove('commented');
        icon.textContent = '💬';
        commentCountSpan.textContent = parseInt(commentCountSpan.textContent) - 1;
    } else {
        button.classList.add('commented');
        icon.textContent = '🗨️';
        commentCountSpan.textContent = parseInt(commentCountSpan.textContent) + 1;
    }
}

function toggleShare(button) {
    const shareCountSpan = button.querySelector('.share-count');
    const icon = button.querySelector('.icon');

    if (button.classList.contains('shared')) {
        button.classList.remove('shared');
        icon.textContent = '🔄';
        shareCountSpan.textContent = parseInt(shareCountSpan.textContent) - 1;
    } else {
        button.classList.add('shared');
        icon.textContent = '✅';
        shareCountSpan.textContent = parseInt(shareCountSpan.textContent) + 1;
    }
}

    </script>
  </body>
</html>
